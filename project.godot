[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method.mobile="gl_compatibility"
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
textures/default_filters/anisotropic_filtering_level=4
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.055, 0.035, 0.12, 1)
anti_aliasing/quality/use_taa=true
occlusion_culling/use_occlusion_culling=true
anti_aliasing/quality/screen_space_roughness_limiter/enabled=true
anti_aliasing/quality/screen_space_roughness_limiter/amount=0.22
anti_aliasing/quality/screen_space_roughness_limiter/limit=0.18
